    <array id="y" size="[3]"> 1..5 </array>
  </variables>
  <constraints>
    <allDifferent> x[] </allDifferent>
    <allDifferent> y[] </allDifferent>
  </constraints>
  <objectives>
    <minimize type="sum"> x[] </minimize>
  </objectives>
</instance>
