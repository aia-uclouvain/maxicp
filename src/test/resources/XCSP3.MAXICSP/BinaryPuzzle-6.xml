<instance format="XCSP3" type="CSP">
  <variables>
    <array id="x" note="x[i][j] is the value in the cell of the grid at coordinates (i,j)" size="[6][6]"> 0 1 </array>
  </variables>
  <constraints>
    <group note="ensuring the same number of 0s and 1s in rows">
      <sum>
        <list> %... </list>
        <condition> (eq,3) </condition>
      </sum>
      <args> x[0][] </args>
      <args> x[1][] </args>
      <args> x[2][] </args>
      <args> x[3][] </args>
      <args> x[4][] </args>
      <args> x[5][] </args>
    </group>
    <group note="ensuring the same number of 0s and 1s in columns">
      <sum>
        <list> %... </list>
        <condition> (eq,3) </condition>
      </sum>
      <args> x[][0] </args>
      <args> x[][1] </args>
      <args> x[][2] </args>
      <args> x[][3] </args>
      <args> x[][4] </args>
      <args> x[][5] </args>
    </group>
    <group note="forbidding sequences of 3 consecutive 0s or 1s in rows">
      <sum>
        <list> %0 %1 %2 </list>
        <condition> (in,1..2) </condition>
      </sum>
      <args> x[0][0..2] </args>
      <args> x[0][1..3] </args>
      <args> x[0][2..4] </args>
      <args> x[0][3..5] </args>
      <args> x[1][0..2] </args>
      <args> x[1][1..3] </args>
      <args> x[1][2..4] </args>
      <args> x[1][3..5] </args>
      <args> x[2][0..2] </args>
      <args> x[2][1..3] </args>
      <args> x[2][2..4] </args>
      <args> x[2][3..5] </args>
      <args> x[3][0..2] </args>
      <args> x[3][1..3] </args>
      <args> x[3][2..4] </args>
      <args> x[3][3..5] </args>
      <args> x[4][0..2] </args>
      <args> x[4][1..3] </args>
      <args> x[4][2..4] </args>
      <args> x[4][3..5] </args>
      <args> x[5][0..2] </args>
      <args> x[5][1..3] </args>
      <args> x[5][2..4] </args>
      <args> x[5][3..5] </args>
    </group>
    <group note="forbidding sequences of 3 consecutive 0s or 1s in columns">
      <sum>
        <list> %0 %1 %2 </list>
        <condition> (in,1..2) </condition>
      </sum>
      <args> x[0..2][0] </args>
      <args> x[1..3][0] </args>
      <args> x[2..4][0] </args>
      <args> x[3..5][0] </args>
      <args> x[0..2][1] </args>
      <args> x[1..3][1] </args>
      <args> x[2..4][1] </args>
      <args> x[3..5][1] </args>
      <args> x[0..2][2] </args>
      <args> x[1..3][2] </args>
      <args> x[2..4][2] </args>
      <args> x[3..5][2] </args>
      <args> x[0..2][3] </args>
      <args> x[1..3][3] </args>
      <args> x[2..4][3] </args>
      <args> x[3..5][3] </args>
      <args> x[0..2][4] </args>
      <args> x[1..3][4] </args>
      <args> x[2..4][4] </args>
      <args> x[3..5][4] </args>
      <args> x[0..2][5] </args>
      <args> x[1..3][5] </args>
      <args> x[2..4][5] </args>
      <args> x[3..5][5] </args>
    </group>
    <allDifferent note="forbidding identical rows">
      <list> x[0][] </list>
      <list> x[1][] </list>
      <list> x[2][] </list>
      <list> x[3][] </list>
      <list> x[4][] </list>
      <list> x[5][] </list>
    </allDifferent>
    <allDifferent note="forbidding identical columns">
      <list> x[][0] </list>
      <list> x[][1] </list>
      <list> x[][2] </list>
      <list> x[][3] </list>
      <list> x[][4] </list>
      <list> x[][5] </list>
    </allDifferent>
  </constraints>
</instance>
